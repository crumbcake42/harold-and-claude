# sca-tracker backend environment

# Database URL — driven via Pydantic settings per ADR-0051.
#
# Two supported modes:
#
# (1) Neon dev default (per ADR-0051 dev-DB workflow). Each dev machine on its
#     own Neon branch off main. Format:
#       DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>.neon.tech/<db>?sslmode=require
#
# (2) SQLite offline fallback (per ADR-0051 + ADR-0052; explicitly NOT
#     production-equivalent — degraded isolation per ADR-0056). Format:
#       DATABASE_URL=sqlite:///./dev.db
#
# CI runs against docker-compose Postgres in the runner; the vendor-coupled
# ephemeral-branch wiring stays deferred per ADR-0055.

DATABASE_URL=postgresql+psycopg://user:password@host.neon.tech/dbname?sslmode=require
